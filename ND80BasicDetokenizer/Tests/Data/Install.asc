5 'INSTALL/BAS    Voice of Peace BBS setup program
                                                     Written by: Dani Dudovitz              06/19/85
10 CLS:CLEAR 2000:DEFINT B-Z:DEFSTR A:DIM A(12),DS$(3):N$=STRING$(63,95):L=3:M=26:N=31:R=55:A2=CHR$(31):A1=A2+"Enter new Data: ":MN=0:CL$=STRING$(8,13)
12 DEFFNSS$(A$)=LEFT$(A$+"  ",INSTR(A$+"  ","  ")-1)
13 DEFFNDN!(Y%,M%,D%)=Y%*365+INT((Y%-1)/4)+(M%-1)*28+VAL(MID$("000303060811131619212426",(M%-1)*2+1,2))-((M%>2)AND((Y%ANDNOT-4)=0))+D%
14 DEFFNDY$(N!)=MID$("Friday   Saturday Sunday   Monday   Tuesday  WednesdayThursday ",(N!-INT(N!/7)*7)*9+1,9)
15 DEFFNMO$(A%)=MID$("January  February March    April    May      June     July     August   SeptemberOctober  November December",((A%-1)*9)+1,9)
16 DEF FNST$(A%)=MID$(STR$(A%),2)
17 DEF FNSP$(A%,A$)=CHR$(21)+CHR$(A%)+"  "+A$+"  "+CHR$(A%)+CHR$(21)
50 PRINT TAB(3)"Voice of Peace - Install Program" TAB(48)"Version 1.0":PRINT TAB(3)"Written by: Dani Dudovitz   Copyright (C) DD Systems Inc.":PRINT N$:PRINT @832,N$
60 OPEN"R",1,"CONFIG/CTL","FF",256:GET 1,1,1000:CLOSE
70 IF MN THEN 200
100 MN=0:PRINT @192,CL$:PRINT @216,FNSP$(194,"MENU A"):PRINT @259,"A) Drive for Uploads";TAB(M);A$(0);TAB(N)"B) Drive for Downloads";TAB(R);":";FNST$(ASC(A$(1))-4):PRINT @323,"C) Sysop DL Drive #";TAB(M);A$(2);TAB(N);
110 PRINT"D) Credits Gained";TAB(R);":";FNST$(ASC(A$(3))):PRINT @387,"E) Credits Lost";TAB(M);":";FNST$(ASC(A$(4)));TAB(N);"F) Days before Delete";TAB(R);":";FNST$(ASC(A$(7)))
120 PRINT @515,"G) BBS   Name";TAB(14);": ";TAB(N);A$(6):PRINT @579,"H) Sysop Name";TAB(14)": ";TAB(N);A$(5)
130 Y1%=VAL(MID$(DA$,7,2))+1900:M1%=VAL(LEFT$(DA$,2)):D1%=VAL(MID$(DA$,4,2)):ED$=FNSS$(FNDY$(FNDN!(Y1%,M1%,D1%)))+", "+FNSS$(FNMO$(M1%))+STR$(D1%)+", 19"+MID$(DA$,7,2)
140 PRINT @707,"Last Day running";TAB(N);ED$:PRINT @771,"Highest Call :";CN;TAB(N)"Chat Activated: ";
150 IF CF$="Y" THEN PRINT"Yes"; ELSE PRINT"No";
160 PRINT @899,CHR$(30);"Press:   (A-H) to Edit, (I) to Install, (R) to Record,":PRINT @974,"(Q) to Quit, (M)enu B";:GOTO 300
200 MN=-1:PRINT @216,FNSP$(194,"MENU B"):PRINT @254,CL$:PRINT @259,"J) Drive for Messages";TAB(N);A$(8):PRINT @323,"K) Editor Password";TAB(N);":";A$(9)
210 PRINT @387,"L) Secondary Password";TAB(N);":";A$(10):PRINT @451,"N) Basic Password";TAB(N);":";A$(11):PRINT @579,"Disk Operating System";TAB(N);":";DS$(ASC(A$(12)))
220 PRINT @899,CHR$(30);"Press:   (J,K,L,N) to Edit, or (M)enu A":GOTO 300
300 GOSUB 2000:B=INSTR("ABCDEHGFJKLNIQRM",A):IF B=0 THEN 300 ELSE ON INSTR("IRQM",A) GOTO 500,650,660,670
400 Q=1:GOSUB 410:Q=0:GOTO 70
410 IF (INSTR("DEF",A) AND NOT MN) THEN GOSUB 2200:LINE INPUT A$(B-1):A$(B-1)=CHR$(VAL(A$(B-1))):RETURN
420 IF (INSTR("AC",A) AND NOT MN) OR (A="J" AND MN) THEN GOSUB 2200:LINE INPUT B$:MID$(A$(B-1),2,1)=B$:RETURN
430 IF A="B" THEN GOSUB 2200:LINE INPUT B$:A$(B-1)=CHR$(VAL(B$)+4):RETURN
440 IF (INSTR("GH",A) AND NOT MN) OR (INSTR("KLN",A) AND MN) THEN GOSUB 2200:LINE INPUT A$(B-1):PRINT @543+(64*(7-B)),CHR$(30);:RETURN ELSE RETURN
500 CLS:MN=0:PRINT"Are you sure you want to do this? ";:GOSUB 2000:IF A="N" THEN RUN ELSE PRINT"Yes"
510 PRINT"Which drive will contain the uploads? ";:A="A":B=1:GOSUB 410
520 PRINT"Which drive will contain downloads? ";:A="B":B=2:GOSUB 410
530 PRINT"Which drive will you let the remote Sysop look at? ";:A="C":B=3:GOSUB 410
540 PRINT"Which drive will contain the message bases? ";:A="C":B=9:GOSUB 420
550 PRINT"Credits gained on Upload? ";:A="D":B=4:GOSUB 410
560 PRINT"Credits lost on Download? ";:A="E":B=5:GOSUB 410
570 PRINT"How many days between calls before user is deleted? ";:A="F":B=8:GOSUB 410
580 PRINT"Secondary password for remote SYSOP (10 chars max)? ";:LINE INPUT A$(10)
590 PRINT"Password to access Basic from remote? ";:LINE INPUT A$(11)
600 PRINT"Password to access the Editor from remote? ";:LINE INPUT A$(9)
610 PRINT"What will you name the BBS (20 chars max)? ";:LINE INPUT A$(6)
620 PRINT"What name do you want to use (10 chars max)? ";:LINE INPUT A$(5)
630 PRINT:PRINT"Reintialize Call Counter? ";:GOSUB 2000:IF A="Y" THEN PRINT "Yes":CN%=0:ELSE PRINT "No"
640 PRINT"Record New Information? ";:GOSUB 2000:IF A="Y" THEN PRINT "Yes":GOTO 650 ELSE RUN
650 PRINT @899,CHR$(31);"Please Wait.....";:OPEN"R",1,"CONFIG/CTL","FF",256:PUT 1,1,1000:CLOSE:RUN
660 CLS:END
670 MN=NOT MN:GOTO 70
1000 (2)A$(0),(1)A$(1),(2)A$(2),(1)A$(3),(1)A$(4),(10)A$(5),(20)A$(6),(17)DA$,CN%,(1)CF$,(1)A$(7),(2)A$(8),(10)A$(9),(10)A$(10),(10)A$(11),(1)A$(12),(135)$,(9)DS$(0),(4)DS$(1),(8)DS$(2),(9)DS$(3);
2000 A=INKEY$:IF A="" THEN 2000 ELSE A$=CHR$(ASC(A$) AND &H5F):RETURN
2200 IF Q THEN PRINT @899,A1;:RETURN ELSE RETURN
30000 SAVE"INSTALL/BAS